      "dev": "concurrently -k -n HEXO,BSYNC \"npm:dev:hexo\" \"npm:dev:reload\"",
      "dev:open": "concurrently -k -n HEXO,BSYNC \"npm:dev:hexo\" \"npm:dev:reload:open\"",
      "dev:hexo": "nodemon --watch _config.yml --watch _config.solitude.yml --watch _config.landscape.yml --watch source --watch layout --watch themes/solitude/layout --watch themes/solitude/source --ext yml,md,pug,ejs,js,css,styl,json --exec \"hexo server -p 4000\"",
      "dev:reload": "browser-sync start --proxy http://localhost:4000 --files \"public/**/*\" --port 4001 --ui-port 4002 --no-open --no-notify --reload-delay 300",
      "dev:reload:open": "browser-sync start --proxy http://localhost:4000 --files \"public/**/*\" --port 4001 --ui-port 4002 --open local --no-notify --reload-delay 300",
      "deploy": "hexo deploy",
      "server": "hexo server"
    }
  },
